# ── Root .env.example ──
# Copy relevant sections to frontend/.env.local and backend/.env

# FRONTEND
NEXT_PUBLIC_API_URL=http://localhost:5000/api
NEXT_PUBLIC_APP_NAME=EcoSmart AI

# BACKEND
PORT=5000
NODE_ENV=development
DATABASE_URL=mongodb://localhost:27017/ecosmart
JWT_SECRET=your_jwt_secret_here
ANTHROPIC_API_KEY=your_anthropic_key_here
ALLOWED_ORIGINS=http://localhost:3000
